# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: encryption key for PsychologistAgent memory.
# If not set, a local key will be generated automatically in storage/secure/.psychologist_key
PSYCHOLOGIST_ENCRYPTION_KEY=

# Optional: real-time search APIs for CulturalAgent
TAVILY_API_KEY=
GOOGLE_API_KEY=
